{
  "name": "loadout",
  "version": "0.1.0",
  "description": "Composable configuration bundles for AI coding agents",
  "type": "module",
  "bin": {
    "loadout": "./dist/index.js"
  },
  "files": [
    "dist",
    "docs"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "loadout": "node dist/index.js"
  },
  "keywords": [
    "ai",
    "agents",
    "cli",
    "configuration",
    "claude",
    "cursor",
    "opencode",
    "codex"
  ],
  "author": "Evatt",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.12.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "yaml": "^2.4.0",
    "zod": "^3.23.0",
    "chalk": "^5.3.0"
  },
  "engines": {
    "node": ">=18"
  }
}
